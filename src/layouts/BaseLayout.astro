---
const {
  title = "Arslan Çelik Kapı",
  description = "Özel ölçü çelik kapı, yangın kapısı ve bina giriş kapısı çözümleri.",
} = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <footer>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="logo" href="/">
              <div class="logo-icon">
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="3" y="2" width="10" height="16" rx="1.5" stroke="white" stroke-width="1.8"></rect>
                  <rect x="5" y="5" width="3.5" height="4.5" rx="0.5" stroke="white" stroke-width="1.3"></rect>
                  <rect x="5" y="11" width="3.5" height="4.5" rx="0.5" stroke="white" stroke-width="1.3"></rect>
                  <circle cx="14.5" cy="10" r="1.2" fill="white"></circle>
                  <line x1="13" y1="10" x2="16.5" y2="10" stroke="white" stroke-width="1.5" stroke-linecap="round"></line>
                </svg>
              </div>
              <div class="logo-text">
                <div class="brand">ARSLAN ÇELİK KAPI</div>
                <div class="sub">Özel Ölçü Üretim</div>
              </div>
            </a>
            <p class="brand-desc">
              Çelik kapı, yangın kapısı ve bina giriş kapısı üretiminde özel ölçü çözümler sunar.
              Projeleriniz için hızlı teklif ve teknik destek alabilirsiniz.
            </p>
          </div>

          <div class="footer-col">
            <h4>Kurumsal</h4>
            <ul>
              <li><a href="/">Anasayfa</a></li>
              <li><a href="/hakkimizda/">Hakkımızda</a></li>
              <li><a href="/projeler/">Projeler</a></li>
              <li><a href="/blog/">Blog</a></li>
              <li><a href="/iletisim/">İletişim</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Ürünler</h4>
            <ul>
              <li><a href="/urunler/?kategori=celik-kapi">Çelik Kapı Modelleri</a></li>
              <li><a href="/urunler/?kategori=yangin-kapisi">Yangın Kapı Modelleri</a></li>
              <li><a href="/urunler/?kategori=bina-giris-kapisi">Villa ve Apartman Kapıları</a></li>
            </ul>
          </div>

          <div class="footer-col">
