---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const relatedPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((item) => item.slug !== post.slug)
  .slice(0, 3);
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.excerpt}>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a class="active" href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero blog-detail-hero">
      <div class="container hero-inner">
        <p class="breadcrumb">
          <a href="/">Anasayfa</a>
          <span>/</span>
          <a href="/blog/">Blog</a>
          <span>/</span>
          <strong>{post.data.title}</strong>
        </p>
        <span class="hero-label">Blog Yazısı</span>
        <h1>{post.data.title}</h1>
        <p>{post.data.excerpt}</p>
      </div>
    </section>

    <section class="blog-detail-section">
      <div class="container">
        <article class="blog-detail-card">
          <img class="blog-detail-image" src={post.data.cover} alt={`${post.data.title} görseli`} />
          <p class="blog-date">{post.data.publishedAt}</p>
          <div class="blog-content">
            <Content />
          </div>
          <div class="detail-actions">
            <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
            <a class="btn-secondary" href="/blog/">Blog Listesine Dön</a>
          </div>
        </article>
      </div>
    </section>

    {
      relatedPosts.length > 0 && (
        <section class="related-section">
          <div class="container">
            <div class="section-head">
              <div>
                <h3 class="section-title">Diğer Yazılar</h3>
                <p class="section-desc">Blogdaki diğer içeriklere de göz atabilirsiniz.</p>
              </div>
            </div>
            <div class="blog-grid">
              {relatedPosts.map((item) => (
                <article class="blog-card">
                  <a class="blog-image-wrap" href={`/blog/${item.slug}/`}>
                    <img class="blog-image" src={item.data.cover} alt={`${item.data.title} görseli`} loading="lazy" />
                  </a>
                  <div class="blog-body">
                    <p class="blog-date">{item.data.publishedAt}</p>
                    <h4 class="blog-title">
                      <a href={`/blog/${item.slug}/`}>{item.data.title}</a>
                    </h4>
                    <p class="blog-excerpt">{item.data.excerpt}</p>
                    <a class="blog-link" href={`/blog/${item.slug}/`}>Devamını Oku</a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>
<style>
  .blog-detail-hero .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .blog-detail-hero .breadcrumb {
    justify-content: center;
  }

  .blog-detail-hero .hero-inner > p {
    max-width: 860px;
    margin-inline: auto;
  }
</style>
</BaseLayout>





