---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);

const posts = blogPosts.slice(0, 10);

const row1 = posts.slice(0, 2);
const row2 = posts.slice(2, 5);
const row3 = posts.slice(5, 7);
const row4 = posts.slice(7, 9);
const row5 = posts.slice(9, 10);

const formatDate = (value: string) => {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString("tr-TR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });
};

const inferCategory = (title: string) => {
  const normalized = title.toLocaleLowerCase("tr-TR");
  if (normalized.includes("yangın")) return "Yangın Kapısı";
  if (normalized.includes("bina") || normalized.includes("giriş") || normalized.includes("apartman")) return "Bina Giriş Kapısı";
  return "Çelik Kapı";
};
---

<BaseLayout title="Blog | Arslan Çelik Kapı" description="Kapı seçimi, güvenlik ve uygulama süreçleri hakkında blog yazıları.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a class="active" href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1>Bilgi ve <span>Rehber Yazıları</span></h1>
        <p>Kapı seçimi, güvenlik ihtiyaçları ve uygulama süreçleri hakkında kısa ve faydalı içerikler.</p>
      </div>
    </section>

    <section class="blog-section">
      <div class="container editorial-wrapper">
        {
          posts.length > 0 ? (
            <div class="editorial-grid" aria-label="Blog yazıları liste görünümü">
              {
                row1.length > 0 && (
                  <div class="editorial-row row-1">
                    {row1.map((post, index) => {
                      const isLarge = index === 0 || row1.length === 1;
                      return (
                        <article class:list={["editorial-item", isLarge ? "size-large" : "size-small"]}>
                          <a class="editorial-link" href={`/blog/${post.slug}/`}>
                            <div class="editorial-media">
                              <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                            </div>
                            <div class="editorial-content">
                              <p class="editorial-category">{inferCategory(post.data.title)}</p>
                              <h2>{post.data.title}</h2>
                              {isLarge && post.data.excerpt && <p class="editorial-excerpt">{post.data.excerpt}</p>}
                              <p class="editorial-date">{formatDate(post.data.publishedAt)}</p>
                            </div>
                          </a>
                        </article>
                      );
                    })}
                  </div>
                )
              }

              {
                row2.length > 0 && (
                  <div class="editorial-row row-2">
                    {row2.map((post) => (
                      <article class="editorial-item size-compact">
                        <a class="editorial-link" href={`/blog/${post.slug}/`}>
                          <div class="editorial-media">
                            <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                          </div>
                          <div class="editorial-content">
                            <p class="editorial-category">{inferCategory(post.data.title)}</p>
                            <h3>{post.data.title}</h3>
                            <p class="editorial-date">{formatDate(post.data.publishedAt)}</p>
                          </div>
                        </a>
                      </article>
                    ))}
                  </div>
                )
              }

              {
                row3.length > 0 && (
                  <div class="editorial-row row-3">
                    {row3.map((post, index) => {
                      const isLarge = row3.length === 1 ? true : index === 1;
                      return (
                        <article class:list={["editorial-item", isLarge ? "size-large" : "size-small"]}>
                          <a class="editorial-link" href={`/blog/${post.slug}/`}>
                            <div class="editorial-media">
                              <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                            </div>
                            <div class="editorial-content">
                              <p class="editorial-category">{inferCategory(post.data.title)}</p>
                              <h2>{post.data.title}</h2>
                              {isLarge && post.data.excerpt && <p class="editorial-excerpt">{post.data.excerpt}</p>}
                              <p class="editorial-date">{formatDate(post.data.publishedAt)}</p>
                            </div>
                          </a>
                        </article>
                      );
                    })}
                  </div>
                )
              }

              {
                row4.length > 0 && (
                  <div class="editorial-row row-4">
                    {row4.map((post) => (
                      <article class="editorial-item size-horizontal">
                        <a class="editorial-link horizontal-link" href={`/blog/${post.slug}/`}>
                          <div class="editorial-media horizontal-media">
                            <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                          </div>
                          <div class="editorial-content horizontal-content">
                            <p class="editorial-category">{inferCategory(post.data.title)}</p>
                            <h3>{post.data.title}</h3>
                            <p class="editorial-date">{formatDate(post.data.publishedAt)}</p>
                          </div>
                        </a>
                      </article>
                    ))}
                  </div>
                )
              }

              {
                row5.length > 0 && (
                  <div class="editorial-row row-5">
                    {row5.map((post) => (
                      <article class="editorial-item size-full-horizontal">
                        <a class="editorial-link horizontal-link" href={`/blog/${post.slug}/`}>
                          <div class="editorial-media horizontal-media">
                            <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                          </div>
                          <div class="editorial-content horizontal-content">
                            <p class="editorial-category">{inferCategory(post.data.title)}</p>
                            <h2>{post.data.title}</h2>
                            {post.data.excerpt && <p class="editorial-excerpt">{post.data.excerpt}</p>}
                            <p class="editorial-date">{formatDate(post.data.publishedAt)}</p>
                          </div>
                        </a>
                      </article>
                    ))}
                  </div>
                )
              }
            </div>
          ) : (
            <div class="product-empty">Henüz yayınlanmış blog yazısı yok.</div>
          )
        }
      </div>
    </section>
  </main>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap");

    .blog-section {
  background: #ffffff;
    }

    .blog-section .container.editorial-wrapper,
    .editorial-wrapper {
    background: #ffffff;
    }

    .hero-inner {
      text-align: center;
    }

    .hero-inner h1 {
      margin-inline: auto;
      text-align: center;
    }

    .hero-inner p {
      margin-inline: auto;
      text-align: center;
      max-width: 860px;
    }

    .blog-section .container.editorial-wrapper {
      width: min(80vw, 1440px);
      max-width: min(80vw, 1440px);
      margin-inline: auto;
      padding-inline: 0;
    }

    .editorial-wrapper {
      --ink: #161310;
      --line-soft: rgba(22, 19, 16, 0.22);
      --line-medium: rgba(22, 19, 16, 0.34);
      --muted: #57524c;
      --paper: #ffffff;
      --line-strong: 1px;
      background: #ffffff;
    }

    .editorial-grid {
      border-top: 1px solid var(--line-medium);
      border-bottom: 1px solid var(--line-soft);
    }

    .editorial-row {
      display: grid;
      position: relative;
      gap: 28px;
      padding-block: 14px;
    }

    .editorial-row + .editorial-row {
      border-top: 1px solid var(--line-soft);
    }

    .row-1 {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    }

    .row-2 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .row-3 {
      grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    }

    .row-4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .row-5 {
      grid-template-columns: minmax(0, 1fr);
    }

    .editorial-item {
      position: relative;
      min-width: 0;
    }

    .editorial-item + .editorial-item::before {
      content: "";
      position: absolute;
      left: -14px;
      top: 16px;
      bottom: 16px;
      width: 1px;
      background: var(--ink);
      opacity: 0.95;
      pointer-events: none;
    }

    .editorial-link {
      color: #111;
      text-decoration: none;
      display: block;
      height: 100%;
      background: var(--paper);
    }

    .editorial-media {
      width: 100%;
      overflow: hidden;
      background: #ffffff;
    }

    .size-large .editorial-media {
      height: clamp(240px, 24vw, 340px);
    }

    .size-small .editorial-media {
      height: clamp(160px, 16vw, 220px);
    }

    .size-compact .editorial-media {
      height: clamp(150px, 14vw, 200px);
    }

    .size-horizontal .horizontal-media,
    .size-full-horizontal .horizontal-media {
      width: 42%;
      flex: 0 0 42%;
      height: clamp(170px, 18vw, 230px);
    }

    .size-full-horizontal .horizontal-media {
      height: clamp(200px, 20vw, 260px);
    }

    .editorial-media img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      display: block;
      filter: grayscale(15%) saturate(75%) contrast(95%);
      transition: transform 0.25s ease, filter 0.25s ease;
    }

    .editorial-content {
      padding: 10px 14px 12px;
      background: var(--paper);
    }

    .editorial-content::before {
      content: "";
      display: block;
      height: 1px;
      background: var(--line-soft);
      margin-bottom: 10px;
      opacity: 0.92;
    }

    .horizontal-link {
      display: flex;
      align-items: stretch;
      position: relative;
    }

    .horizontal-link::before {
      content: "";
      position: absolute;
      left: 42%;
      top: 16px;
      bottom: 16px;
      width: 1px;
      background: var(--ink);
      pointer-events: none;
    }

    .horizontal-link .horizontal-content {
      padding: 11px 14px 12px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .horizontal-link .horizontal-content::before {
      display: none;
    }

    .editorial-category {
      margin: 0 0 6px;
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #2a2520;
      font-weight: 600;
      font-family: Inter, "Segoe UI", sans-serif;
    }

    .editorial-content h2,
    .editorial-content h3 {
      margin: 0;
      color: #161310;
      line-height: 1.14;
      font-family: "Fraunces", "Cormorant Garamond", Georgia, "Times New Roman", serif;
      font-weight: 600;
      transition: opacity 0.2s ease;
    }

    .editorial-content h2 {
      font-size: clamp(29px, 2.5vw, 40px);
    }

    .size-small .editorial-content h2,
    .size-compact .editorial-content h3,
    .size-horizontal .editorial-content h3 {
      font-size: clamp(20px, 1.5vw, 28px);
    }

    .size-full-horizontal .editorial-content h2 {
      font-size: clamp(24px, 2.1vw, 34px);
    }

    .editorial-excerpt {
      margin: 8px 0 7px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
      font-family: Inter, "Segoe UI", sans-serif;
    }

    .editorial-date {
      margin: 7px 0 0;
      color: #4e4a44;
      font-size: 11px;
      letter-spacing: 0.02em;
      font-family: Inter, "Segoe UI", sans-serif;
    }

    .editorial-link:hover .editorial-content h2,
    .editorial-link:hover .editorial-content h3 {
      opacity: 0.84;
    }

    .editorial-link:hover .editorial-media img {
      transform: scale(1.02);
      filter: grayscale(8%) saturate(90%) contrast(100%);
    }

    .editorial-link:focus-visible {
      outline: 2px solid #1b1b1b;
      outline-offset: -2px;
    }

    @media (max-width: 1100px) {
      .blog-section .container.editorial-wrapper {
        width: min(90vw, 1200px);
        max-width: min(90vw, 1200px);
      }

      .editorial-row {
        gap: 22px;
      }

      .editorial-item + .editorial-item::before {
        left: -11px;
        top: 14px;
        bottom: 14px;
      }
    }

    @media (max-width: 768px) {
      .blog-section .container.editorial-wrapper {
        width: min(100vw - 32px, 100%);
        max-width: min(100vw - 32px, 100%);
      }

      .editorial-row {
        grid-template-columns: minmax(0, 1fr) !important;
        gap: 14px;
        padding-block: 12px;
      }

      .editorial-item + .editorial-item::before,
      .horizontal-link::before {
        display: none;
      }

      .editorial-item + .editorial-item {
      .border-top: 1px solid var(--line-soft);
      }

      .horizontal-link {
        display: block;
      }

      .size-horizontal .horizontal-media,
      .size-full-horizontal .horizontal-media {
        width: 100%;
        height: clamp(180px, 48vw, 240px);
      }

      .size-large .editorial-media {
        height: clamp(210px, 56vw, 280px);
      }

      .size-small .editorial-media,
      .size-compact .editorial-media {
        height: clamp(180px, 50vw, 240px);
      }

      .horizontal-link .horizontal-content::before {
        display: block;
      }

      .editorial-content {
        padding: 9px 12px 11px;
      }

      .editorial-content h2,
      .editorial-content h3,
      .size-small .editorial-content h2,
      .size-compact .editorial-content h3,
      .size-horizontal .editorial-content h3,
      .size-full-horizontal .editorial-content h2 {
        font-size: clamp(22px, 6.2vw, 30px);
      }
    }
  </style>
</BaseLayout>




