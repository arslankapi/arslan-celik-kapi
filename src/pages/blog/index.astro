---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime(),
);

const firstPost = blogPosts[0];
const secondPost = blogPosts[1];
const thirdRowPosts = blogPosts.slice(2, 4);
const remainingPosts = blogPosts.slice(4);
---

<BaseLayout title="Blog | Arslan Çelik Kapı" description="Kapı seçimi, güvenlik ve uygulama süreçleri hakkında blog yazıları.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a class="active" href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1>Bilgi ve <span>Rehber Yazıları</span></h1>
        <p>Kapı seçimi, güvenlik ihtiyaçları ve uygulama süreçleri hakkında kısa ve faydalı içerikler.</p>
      </div>
    </section>

    <section class="blog-section">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">Son Yazılar</h2>
            <p class="section-desc">Çelik kapılar, yangın kapıları ve bina giriş sistemleri hakkında güncel rehberlere, fiyat bilgilerine ve seçim önerilerine göz atın. Güvenlik, dayanıklılık ve modern tasarımı bir araya getiren içeriklerimizi keşfedin.</p>
          </div>
        </div>

        {
          blogPosts.length > 0 ? (
            <div class="blog-flow">
              {
                firstPost && (
                  <article class="flow-item flow-primary">
                    <a class="flow-media flow-media-primary" href={`/blog/${firstPost.slug}/`}>
                      <img src={firstPost.data.cover} alt={`${firstPost.data.title} görseli`} loading="lazy" />
                    </a>
                    <div class="flow-title">
                      <h3><a href={`/blog/${firstPost.slug}/`}>{firstPost.data.title}</a></h3>
                    </div>
                  </article>
                )
              }

              {
                secondPost && (
                  <article class="flow-item flow-split">
                    <a class="flow-media flow-media-split" href={`/blog/${secondPost.slug}/`}>
                      <img src={secondPost.data.cover} alt={`${secondPost.data.title} görseli`} loading="lazy" />
                    </a>
                    <div class="flow-title flow-title-split">
                      <h3><a href={`/blog/${secondPost.slug}/`}>{secondPost.data.title}</a></h3>
                    </div>
                  </article>
                )
              }

              {
                thirdRowPosts.length > 0 && (
                  <div class="flow-pair">
                    {thirdRowPosts.map((post) => (
                      <article class="flow-item flow-half">
                        <a class="flow-media flow-media-half" href={`/blog/${post.slug}/`}>
                          <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                        </a>
                        <div class="flow-title">
                          <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
                        </div>
                      </article>
                    ))}
                  </div>
                )
              }

              {
                remainingPosts.length > 0 && (
                  <div class="flow-remaining">
                    {remainingPosts.map((post) => (
                      <article class="flow-item flow-row">
                        <a class="flow-media flow-media-row" href={`/blog/${post.slug}/`}>
                          <img src={post.data.cover} alt={`${post.data.title} görseli`} loading="lazy" />
                        </a>
                        <div class="flow-title">
                          <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
                        </div>
                      </article>
                    ))}
                  </div>
                )
              }
            </div>
          ) : (
            <div class="product-empty">Henüz yayınlanmış blog yazısı yok.</div>
          )
        }
      </div>
    </section>
  </main>

  <style>
    .hero-inner {
      text-align: center;
    }

    .hero-inner h1 {
      margin-inline: auto;
      text-align: center;
    }

    .hero-inner p {
      margin-inline: auto;
      text-align: center;
      max-width: 860px;
    }

    .blog-section .section-head {
      width: 100%;
      margin-inline: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
      margin-bottom: 18px;
    }

    .blog-section .section-head .section-title,
    .blog-section .section-head .section-desc {
      text-align: center;
      margin-inline: auto;
    }

    .blog-flow {
      display: grid;
      gap: 28px;
    }

    .flow-item {
      background: transparent;
      border: 0;
      box-shadow: none;
      overflow: hidden;
    }

    .flow-media {
      display: block;
      background: #fff;
      overflow: hidden;
    }

    .flow-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }

    .flow-item:hover .flow-media img {
      transform: scale(1.02);
    }

    .flow-title {
      min-height: 94px;
      background: #fff;
      display: flex;
      align-items: center;
      padding: 20px 24px;
    }

    .flow-title h3 {
      margin: 0;
      font-size: clamp(22px, 2.8vw, 32px);
      line-height: 1.2;
      letter-spacing: -0.02em;
      font-family: "Manrope", sans-serif;
    }

    .flow-half .flow-title h3,
    .flow-row .flow-title h3,
    .flow-split .flow-title h3 {
      font-size: clamp(20px, 2.2vw, 30px);
    }

    .flow-title a {
      text-decoration: none;
      color: #171411;
    }

    .flow-title a:hover {
      color: #b06f1f;
    }

    .flow-media-primary {
      min-height: clamp(340px, 52vw, 560px);
    }

    .flow-split {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      background: #fff;
    }

    .flow-media-split {
      min-height: clamp(180px, 24vw, 280px);
    }

    .flow-title-split {
      min-height: clamp(180px, 24vw, 280px);
      align-items: flex-start;
      padding-top: 24px;
      padding-bottom: 24px;
    }

    .flow-pair {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }

    .flow-media-half {
      min-height: clamp(220px, 28vw, 320px);
    }

    .flow-remaining {
      display: grid;
      gap: 24px;
    }

    .flow-media-row {
      min-height: clamp(220px, 26vw, 300px);
    }

    .flow-media:focus-visible,
    .flow-title a:focus-visible {
      outline: 2px solid #c8842f;
      outline-offset: 3px;
    }

    @media (max-width: 1024px) {
      .flow-split {
        grid-template-columns: 1fr;
      }

      .flow-title-split {
        min-height: 94px;
        align-items: center;
        padding-top: 20px;
        padding-bottom: 20px;
      }

      .flow-pair {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 720px) {
      .blog-flow {
        gap: 18px;
      }

      .flow-pair {
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .flow-title {
        min-height: 86px;
        padding: 16px 18px;
      }

      .flow-title h3,
      .flow-half .flow-title h3,
      .flow-row .flow-title h3,
      .flow-split .flow-title h3 {
        font-size: clamp(18px, 6vw, 26px);
      }

      .flow-media-primary {
        min-height: clamp(240px, 62vw, 360px);
      }

      .flow-media-split,
      .flow-media-half,
      .flow-media-row {
        min-height: clamp(180px, 55vw, 280px);
      }
    }
  </style>
</BaseLayout>
