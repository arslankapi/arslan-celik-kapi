---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

import boyaKurutmaAtolyesi from "../../../hak-gorsel/arslan-celik-kapi-boya-kurutma-atolyesi.jpeg";
import boyamaAtolyesi from "../../../hak-gorsel/arslan-celik-kapi-boyama-atolyesi.jpeg";
import depoBolgesi from "../../../hak-gorsel/arslan-celik-kapi-depo-bolgesi.jpeg";
import dikisUnitesi from "../../../hak-gorsel/arslan-celik-kapi-dikis-unitesi.jpg.jpeg";
import montajAtolyesi from "../../../hak-gorsel/arslan-celik-kapi-montaj-atolyesi.jpeg";
import preslemeUnitesi from "../../../hak-gorsel/arslan-celik-kapi-presleme-unitesi.jpeg";

const gallerySections = [
  {
    title: "Presleme Ünitesi",
    image: preslemeUnitesi,
    alt: "Arslan Çelik Kapı presleme ünitesi",
    theme: "theme-cream",
    text: "Presleme ünitesinde sac yüzeylerin formu, panel derinliği ve geometri sürekliliği kontrollü basınç altında standardize edilir. Bu aşama, kapı kanadının rijitliğini artırırken sonraki dikiş, montaj ve yüzey uygulamalarında ölçü toleranslarının korunmasına doğrudan katkı sağlar.",
  },
  {
    title: "Dikiş Ünitesi",
    image: dikisUnitesi,
    alt: "Arslan Çelik Kapı dikiş ünitesi",
    theme: "theme-dark",
    text: "Dikiş ünitesinde kasa ve kanat birleşim noktaları, malzeme kalınlığına uygun kaynak ve birleştirme disipliniyle tamamlanır. Buradaki işlem kalitesi; gövde mukavemeti, köşe stabilitesi ve uzun süreli kullanımda oluşabilecek deformasyon riskinin azaltılması açısından kritik rol oynar.",
  },
  {
    title: "Montaj Atölyesi",
    image: montajAtolyesi,
    alt: "Arslan Çelik Kapı montaj atölyesi",
    theme: "theme-cream",
    text: "Montaj atölyesinde kilit sistemi, menteşe, kol, karşılık ve yardımcı aksesuarların mekanik uyumu kontrol edilerek kapı seti tamamlanır. Kapanma toleransı, kanat-kasa açıklığı ve donanım hizası bu aşamada test edilerek ürünün sahaya kullanıma hazır şekilde çıkması sağlanır.",
  },
  {
    title: "Boyama Atölyesi",
    image: boyamaAtolyesi,
    alt: "Arslan Çelik Kapı boyama atölyesi",
    theme: "theme-dark",
    text: "Boyama atölyesinde yüzey hazırlığı sonrası kaplama homojenliği, film kalınlığı ve renk sürekliliği esas alınır. Uygulanan proses, metal yüzeyin dış etkilere karşı direncini artırırken estetik görünümde ton farkı, akma ve yüzey düzensizliği gibi risklerin önüne geçer.",
  },
  {
    title: "Boya Kurutma Atölyesi",
    image: boyaKurutmaAtolyesi,
    alt: "Arslan Çelik Kapı boya kurutma atölyesi",
    theme: "theme-cream",
    text: "Boya kurutma atölyesinde uygulanan kontrollü kuruma prosesi, kaplamanın yüzeye doğru şekilde bağlanmasını ve nihai sertliğe ulaşmasını destekler. Bu süreç; çizilme direnci, yüzey bütünlüğü ve uzun vadeli renk stabilitesi açısından boyanın performansını belirleyen temel aşamalardan biridir.",
  },
  {
    title: "Depo Bölgesi",
    image: depoBolgesi,
    alt: "Arslan Çelik Kapı depo bölgesi",
    theme: "theme-dark",
    text: "Depo bölgesinde tamamlanan ürünler proje, ölçü ve sevkiyat planına göre kontrollü biçimde ayrıştırılır. Bu düzen; ürünlerin yükleme öncesi hasarsız korunmasını, montaj sırasına uygun sevk edilmesini ve saha operasyonlarında zaman kaybının önlenmesini sağlar.",
  },
] as const;
---

<BaseLayout title="Hakkımızda | Arslan Çelik Kapı" description="Arslan Çelik Kapı üretim alanları, ofis yapısı ve üretim yaklaşımı hakkında bilgiler.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a class="active" href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href="/iletisim/">Teklif Al</a>
    </div>
  </header>

  <main id="main-content" class="about-page">
    <section class="about-hero">
      <div class="container about-hero-inner">
        <p class="page-kicker">Üretim Tesisimiz</p>
        <h1>400 m² imalat alanı ve 50 m² ofis bölümüyle, üretimden sevkiyata kadar tüm süreci aynı çatı altında yönetiyoruz.</h1>
        <p class="page-intro">
          Arslan Çelik Kapı olarak üretim disiplinimizi yalnızca kapı imalatında değil; planlama, yüzey uygulama, montaj hazırlığı ve teslimat
          koordinasyonunda da aynı titizlikle sürdürüyoruz. Aşağıda tesisimizin farklı bölümlerini ve her bir alanın üretim kalitesine sağladığı katkıyı inceleyebilirsiniz.
        </p>
      </div>
    </section>

    <section class="about-facts">
      <div class="container facts-grid">
        <article class="fact-card">
          <span class="fact-number">400 m²</span>
          <span class="fact-label">İmalat Bölümü</span>
          <p>Kesim, presleme, dikiş, montaj ve yüzey uygulama süreçlerini tek üretim akışında yönetiyoruz.</p>
        </article>
        <article class="fact-card">
          <span class="fact-number">50 m²</span>
          <span class="fact-label">Ofis Bölümü</span>
          <p>Teklif hazırlığı, proje takibi, müşteri iletişimi ve üretim planlamasını ofis ekibimiz koordine ediyor.</p>
        </article>
      </div>
    </section>

    {
      gallerySections.map((section, index) => (
        <section class={`about-showcase ${section.theme}`} aria-labelledby={`about-showcase-${index}`}>
          <div class={`container showcase-grid ${index % 2 === 1 ? "is-reversed" : ""}`}>
            <div class="showcase-media">
              <div class="showcase-frame">
                <Image
                  src={section.image}
                  alt={section.alt}
                  widths={[640, 960, 1280]}
                  sizes="(max-width: 900px) calc(100vw - 32px), (max-width: 1200px) 50vw, 620px"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  class="showcase-image"
                />
              </div>
            </div>
            <div class="showcase-copy">
              <p class="showcase-kicker">Üretim Alanı</p>
              <h2 id={`about-showcase-${index}`}>{section.title}</h2>
              <p>{section.text}</p>
            </div>
          </div>
        </section>
      ))
    }
  </main>

  <style>
    .about-page {
      background: #f6f1e8;
    }

    .about-hero {
      padding: clamp(56px, 9vw, 110px) 0 clamp(32px, 6vw, 60px);
      background:
        radial-gradient(circle at top, rgba(214, 147, 35, 0.18), transparent 48%),
        linear-gradient(180deg, #171310 0%, #221912 100%);
      color: #f4ede4;
    }

    .about-hero-inner {
      display: grid;
      gap: 18px;
      text-align: center;
      justify-items: center;
    }

    .page-kicker {
      margin: 0;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #d69323;
      font-size: 13px;
      font-weight: 700;
    }

    .about-hero h1 {
      margin: 0;
      max-width: 1080px;
      font-size: clamp(34px, 5vw, 68px);
      line-height: 1.06;
    }

    .page-intro {
      max-width: 860px;
      margin: 0;
      color: rgba(244, 237, 228, 0.82);
      font-size: clamp(16px, 2vw, 19px);
      line-height: 1.8;
    }

    .about-facts {
      padding: clamp(24px, 4vw, 42px) 0 clamp(18px, 3vw, 28px);
    }

    .facts-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .fact-card {
      background: #fffaf3;
      border: 1px solid rgba(214, 147, 35, 0.18);
      border-radius: 24px;
      padding: clamp(20px, 3vw, 28px);
      box-shadow: 0 16px 38px rgba(53, 35, 18, 0.08);
      display: grid;
      gap: 8px;
    }

    .fact-number {
      font-size: clamp(26px, 4vw, 44px);
      font-weight: 800;
      color: #d69323;
      line-height: 1;
    }

    .fact-label {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #2b1f17;
    }

    .fact-card p {
      margin: 0;
      color: #5b5147;
      line-height: 1.7;
    }

    .about-showcase {
      padding: clamp(30px, 5vw, 56px) 0;
    }

    .theme-cream {
      background: linear-gradient(180deg, #f6f1e8 0%, #fbf7f1 100%);
    }

    .theme-dark {
      background:
        linear-gradient(180deg, rgba(214, 147, 35, 0.08), rgba(214, 147, 35, 0.02)),
        #1e1711;
      color: #f6efe7;
    }

    .showcase-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.06fr) minmax(0, 0.94fr);
      gap: clamp(18px, 4vw, 48px);
      align-items: center;
    }

    .showcase-grid.is-reversed .showcase-media {
      order: 2;
    }

    .showcase-grid.is-reversed .showcase-copy {
      order: 1;
    }

    .showcase-media {
      min-width: 0;
      display: flex;
      justify-content: center;
    }

    .showcase-frame {
      width: min(100%, 680px);
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 28px;
      padding: clamp(10px, 1.8vw, 16px);
      box-shadow: 0 24px 55px rgba(20, 13, 9, 0.16);
      backdrop-filter: blur(2px);
    }

    .theme-cream .showcase-frame {
      background: #fffdf9;
      border-color: rgba(214, 147, 35, 0.14);
    }

    .showcase-image {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 18px;
    }

    .showcase-copy {
      display: grid;
      gap: 14px;
      align-content: center;
    }

    .showcase-kicker {
      margin: 0;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #d69323;
    }

    .showcase-copy h2 {
      margin: 0;
      font-size: clamp(28px, 3.8vw, 48px);
      line-height: 1.08;
      color: inherit;
    }

    .showcase-copy p:last-child {
      margin: 0;
      color: inherit;
      opacity: 0.9;
      font-size: clamp(15px, 1.8vw, 18px);
      line-height: 1.85;
    }

    .theme-cream .showcase-copy h2 {
      color: #1f1712;
    }

    .theme-cream .showcase-copy p:last-child {
      color: #534941;
      opacity: 1;
    }

    @media (max-width: 900px) {
      .facts-grid {
        grid-template-columns: 1fr;
      }

      .showcase-grid,
      .showcase-grid.is-reversed {
        grid-template-columns: 1fr;
      }

      .showcase-grid.is-reversed .showcase-media,
      .showcase-grid.is-reversed .showcase-copy {
        order: initial;
      }

      .showcase-copy {
        text-align: left;
      }

      .showcase-frame {
        width: 100%;
      }
    }

    @media (max-width: 640px) {
      .about-hero {
        padding-top: 48px;
      }

      .about-hero h1 {
        font-size: clamp(30px, 9vw, 44px);
      }

      .page-intro {
        font-size: 15px;
      }

      .fact-card {
        border-radius: 20px;
      }

      .showcase-frame {
        border-radius: 22px;
        padding: 10px;
      }

      .showcase-image {
        border-radius: 14px;
      }
    }
  </style>
</BaseLayout>
