---
import BaseLayout from "../../layouts/BaseLayout.astro";

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";
---

<BaseLayout title="İletişim | Arslan Çelik Kapı" description="Arslan Çelik Kapı ile iletişime geçin, projeniz için teklif alın.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a class="active" href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1>Projeniz için <span>Teklif Alın</span></h1>
        <p>Formu doldurun, ekip en kısa sürede sizinle iletişime geçsin. İsterseniz doğrudan WhatsApp hattından da yazabilirsiniz.</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="container contact-grid">
        <aside class="contact-card">
          <h2>İletişim Bilgileri</h2>
          <p>Uygun kapı modelini birlikte belirleyelim. Ölçü ve kategori bilgisini paylaşmanız yeterli.</p>

	          <div class="contact-list">
	            <a class="contact-item" href="tel:+905416430613">
	              <span class="contact-item-label">Telefon</span>
	              <strong>0541 643 06 13</strong>
	            </a>
	            <a class="contact-item" href="tel:+905320605413">
	              <span class="contact-item-label">Telefon 2</span>
	              <strong>0532 060 54 13</strong>
	            </a>
	            <a class="contact-item" href="https://wa.me/905416430613?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20bilgi%20almak%20istiyorum." target="_blank" rel="noopener noreferrer">
	              <span class="contact-item-label">WhatsApp Hattı 1</span>
	              <strong>0541 643 06 13</strong>
	            </a>
	            <a class="contact-item" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">
	              <span class="contact-item-label">WhatsApp Hattı 2</span>
	              <strong>0532 060 54 13</strong>
	            </a>
            <a class="contact-item" href="mailto:arslancelikkapi@outlook.com">
              <span class="contact-item-label">E-posta</span>
              <strong>arslancelikkapi@outlook.com</strong>
            </a>
            <div class="contact-item">
              <span class="contact-item-label">Çalışma Saatleri</span>
              <strong>Pzt-Cts 08:00 - 18:00</strong>
            </div>
            <div class="contact-item">
              <span class="contact-item-label">Adres</span>
              <strong>Yalı Mah. Ziya Gökalp Cad, 9 No'lu Depo Bölgesi No:5, 34873 Maltepe/İstanbul</strong>
            </div>
          </div>
        </aside>

        <article class="contact-form-card">
          <h2>Teklif Formu</h2>
          <p>Gönderim sonrası mesajınız WhatsApp üzerinden hazır metin olarak açılır.</p>

          <form id="contact-whatsapp-form" class="contact-form">
            <div class="form-row">
              <label>
                Ad Soyad
                <input id="contact-name" name="name" type="text" placeholder="Adınız Soyadınız" required />
              </label>
              <label>
                Telefon
                <input id="contact-phone" name="phone" type="tel" placeholder="05xx xxx xx xx" required />
              </label>
            </div>
            <div class="form-row">
              <label>
                E-posta
                <input id="contact-email" name="email" type="email" placeholder="ornek@mail.com" />
              </label>
              <label>
                Kategori
                <select id="contact-category" name="category" required>
                  <option value="">Seçiniz</option>
                  <option value="Çelik Kapı">Çelik Kapı</option>
                  <option value="Yangın Kapısı">Yangın Kapısı</option>
                  <option value="Bina Giriş Kapısı">Bina Giriş Kapısı</option>
                </select>
              </label>
            </div>
            <label>
              Mesaj
              <textarea id="contact-message" name="message" rows="5" placeholder="Ölçü, renk veya proje detayını yazabilirsiniz." required></textarea>
            </label>
            <button class="btn-primary" type="submit">WhatsApp ile Gönder</button>
          </form>
        </article>
      </div>

      <div class="container contact-map-wrap">
        <article class="contact-map-card">
          <h2>Konum</h2>
          <p>Atölye ve ofis konumumuzu harita üzerinden inceleyebilirsiniz.</p>
          <div class="contact-map-frame">
            <iframe
              title="Arslan Çelik Kapı Konum"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3015.1225838960677!2d29.133151282310727!3d40.91305801757201!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cac423178fa647%3A0xd719301e5d15a1ec!2zQXJzbGFuIMOHZWxpayBLYXDEsQ!5e0!3m2!1str!2str!4v1778003698980!5m2!1str!2str"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </article>
      </div>
    </section>
  </main>

  <style>
    .hero-inner {
      display: grid;
      justify-items: center;
      text-align: center !important;
    }

    .hero-inner h1 {
      margin-inline: auto;
      width: 100%;
      text-align: center !important;
    }

    .hero-inner p {
      margin-inline: auto;
      width: 100%;
      text-align: center !important;
      max-width: 860px;
    }

    .contact-map-wrap {
      margin-top: 18px;
    }

    .contact-map-card {
      background: #fff;
      border: 1px solid #ebe7de;
      border-radius: var(--radius-card);
      padding: clamp(16px, 3vw, 24px);
    }

    .contact-map-card h2 {
      font-size: clamp(22px, 3vw, 30px);
      margin-bottom: 8px;
    }

    .contact-map-card p {
      color: #5f5a53;
      margin-bottom: 14px;
    }

    .contact-map-frame {
      width: 100%;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid #e5ded1;
      background: #f4f1ea;
      min-height: 320px;
    }

    .contact-map-frame iframe {
      width: 100%;
      height: 100%;
      min-height: 320px;
      display: block;
    }

    @media (max-width: 680px) {
      .contact-map-wrap {
        margin-top: 14px;
      }

      .contact-map-frame,
      .contact-map-frame iframe {
        min-height: 260px;
      }
    }
  </style>

  <script is:inline>
    const form = document.getElementById("contact-whatsapp-form");
    if (form) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        const name = document.getElementById("contact-name")?.value?.trim() ?? "";
        const phone = document.getElementById("contact-phone")?.value?.trim() ?? "";
        const email = document.getElementById("contact-email")?.value?.trim() ?? "";
        const category = document.getElementById("contact-category")?.value?.trim() ?? "";
        const message = document.getElementById("contact-message")?.value?.trim() ?? "";

        const lines = [
          "Merhaba, teklif almak istiyorum.",
          `Ad Soyad: ${name}`,
          `Telefon: ${phone}`,
          `Kategori: ${category || "-"}`,
          `E-posta: ${email || "-"}`,
          `Mesaj: ${message}`,
        ];

        const text = encodeURIComponent(lines.join("\n"));
        const url = `https://wa.me/${"905320605413"}?text=${text}`;
        if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
          window.location.href = url;
        } else {
          window.open(url, "_blank", "noopener,noreferrer");
        }
      });
    }
  </script>
</BaseLayout>






