---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import heroMainDoor from "../assets/home/hero-main-door.png";
import showcase01 from "../assets/home/showcase-01.png";
import showcase02 from "../assets/home/showcase-02.png";
import showcase03 from "../assets/home/showcase-03.png";
import deliveryMarmara from "../assets/home/marmara-ucretsiz-teslimat-kurulum.jpeg";
import technicalCutaway from "../assets/home/ozellik-kesit-v2.avif";
import projectProduction from "../assets/home/proje-bazli-uretim.jpeg";

const featuredProductSlugs = [
  "atlas-celik-kapi",
  "karya-celik-kapi",
  "alya-celik-kapi",
  "arya-celik-kapi",
  "ares-yangin-kapisi",
  "duman-yangin-kapisi",
  "asil-bina-giris-kapisi",
  "porta-bina-giris-kapisi",
] as const;

const categoryMap = {
  "celik-kapi": "Çelik Kapı",
  "yangin-kapisi": "Yangın Kapısı",
  "bina-giris-kapisi": "Bina Giriş Kapısı",
} as const;

const badgeClassMap = {
  "celik-kapi": "badge-orange",
  "bina-giris-kapisi": "badge-mustard",
  "yangin-kapisi": "badge-yellow",
} as const;

const allProducts = await getCollection("products", ({ data }) => !data.draft);
const featuredProducts = featuredProductSlugs
  .map((slug) => allProducts.find((product) => product.slug === slug))
  .filter((product): product is (typeof allProducts)[number] => Boolean(product));
---

<BaseLayout title="Arslan Çelik Kapı | Anasayfa" description="Çelik kapı, yangın kapısı ve bina giriş kapısı üretiminde proje odaklı çözümler.">
<!-- HEADER -->
<header>
  <div class="container">
    <div class="header-inner">
      <a class="logo" href="/">
        <div class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></div>
        <div class="logo-text">
          <div class="brand">ARSLAN ÇELİK KAPI</div>
          <div class="sub">Özel Ölçü Üretim</div>
        </div>
      </a>

      <nav class="header-links" aria-label="Ana menü">
        <a href="/" class="active">Anasayfa</a>
        <a href="/urunler/">Ürünler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/projeler/">Projeler</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>

      <div class="header-right">
        <a class="header-phone" href="tel:+905416430613">
          <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>
          0541 643 06 13
        </a>
        <a class="btn-primary" href="/iletisim/">Teklif Al</a>
      </div>
    </div>
  </div>
</header>

<main id="main-content">
<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <h1>Güvenlik ve estetiği<br>bir araya getiren<br><span>çelik kapı</span> çözümleri</h1>
        <p class="hero-desc">Arslan Çelik Kapı; çelik kapı, yangın kapısı, villa ve apartman giriş kapısı üretiminde özel ölçü ve proje bazlı çözümler sunar. İhtiyacınıza uygun model için hızlıca teklif alabilirsiniz.</p>
        <div class="hero-ctas">
          <a href="/iletisim/" class="btn-primary" style="padding:13px 28px; font-size:15px;">Teklif Al</a>
          <a href="/urunler/" class="btn-outline" style="padding:13px 28px; font-size:15px;">Ürünleri İncele</a>
        </div>
        <div class="hero-trust">
          <div class="trust-item">
            <svg viewBox="0 0 16 16" fill="currentColor" style="color:var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.707 6.293-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 1 1 1.414-1.414L7 8.172l3.293-3.293a1 1 0 1 1 1.414 1.414z"/></svg>
            Özel ölçü üretim
          </div>
          <div class="trust-item">
            <svg viewBox="0 0 16 16" fill="currentColor" style="color:var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.707 6.293-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 1 1 1.414-1.414L7 8.172l3.293-3.293a1 1 0 1 1 1.414 1.414z"/></svg>
            Proje bazlı çözümler
          </div>
          <div class="trust-item">
            <svg viewBox="0 0 16 16" fill="currentColor" style="color:var(--gold)"><path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm3.707 6.293-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 1 1 1.414-1.414L7 8.172l3.293-3.293a1 1 0 1 1 1.414 1.414z"/></svg>
            Yangın kapısı seçenekleri
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-img-wrap">
          <Image
            class="hero-main-image"
            src={heroMainDoor}
            alt="Arslan Çelik Kapı ürün görseli"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            widths={[480, 720, 960, 1280]}
            sizes="(max-width: 680px) 100vw, (max-width: 1200px) 45vw, 520px"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-num">500<span>+</span></div>
        <div class="stat-label">Tamamlanan Proje</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">15<span>+</span></div>
        <div class="stat-label">Yıllık Deneyim</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">3</div>
        <div class="stat-label">Ana Ürün Kategorisi</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">24<span>h</span></div>
        <div class="stat-label">Teklif Dönüş Süresi</div>
      </div>
    </div>
  </div>
</div>

<!-- PRODUCT GROUPS -->
<section class="door-showcase" aria-labelledby="door-showcase-title">
  <div class="container">
    <div class="section-head centered">
      <div class="section-label">Ürün Grupları</div>
      <h2 class="section-title light" id="door-showcase-title">Güvenlik, dayanım ve mimari görünüm bir arada</h2>
      <p class="section-desc light">Çelik kapı, yangın kapısı ve bina giriş kapısı kategorilerimizi tek bakışta inceleyin.</p>
    </div>

            <div class="door-staggered-grid">
      <a class="door-staggered-card" href="/urunler/?kategori=celik-kapi" aria-label="Çelik kapı ürünlerini incele">
        <Image
          src={showcase01}
          alt="Çelik kapı modeli"
          loading="lazy"
          widths={[480, 768, 1024]}
          sizes="(max-width: 992px) 100vw, 33vw"
        />
        <div class="door-staggered-overlay">
          <span class="door-staggered-index">01</span>
          <h3>Çelik Kapı</h3>
          <p>Güvenlik ve estetiği bir araya getiren özel ölçü giriş çözümleri.</p>
          <span class="door-staggered-link">İncele</span>
        </div>
      </a>

      <a class="door-staggered-card" href="/urunler/?kategori=yangin-kapisi" aria-label="Yangın kapısı ürünlerini incele">
        <Image
          src={showcase02}
          alt="Yangın kapısı modeli"
          loading="lazy"
          widths={[480, 768, 1024]}
          sizes="(max-width: 992px) 100vw, 33vw"
        />
        <div class="door-staggered-overlay">
          <span class="door-staggered-index">02</span>
          <h3>Yangın Kapısı</h3>
          <p>Yönetmeliklere uygun, dayanıklı ve uzun ömürlü yangın kapısı seçenekleri.</p>
          <span class="door-staggered-link">İncele</span>
        </div>
      </a>

      <a class="door-staggered-card" href="/urunler/?kategori=bina-giris-kapisi" aria-label="Bina giriş kapısı ürünlerini incele">
        <Image
          src={showcase03}
          alt="Bina giriş kapısı modeli"
          loading="lazy"
          widths={[480, 768, 1024]}
          sizes="(max-width: 992px) 100vw, 33vw"
        />
        <div class="door-staggered-overlay">
          <span class="door-staggered-index">03</span>
          <h3>Bina Giriş Kapısı</h3>
          <p>Apartman ve site girişlerinde mimari çizgiye uyumlu güçlü modeller.</p>
          <span class="door-staggered-link">İncele</span>
        </div>
      </a>
    </div>  </div>
</section>

<!-- FEATURE STRIP -->
<section class="feature-strip" aria-label="Teknik özellikler">
  <div class="container">
    <div class="feature-strip-grid">
      <article class="feature-strip-item">
        <div class="feature-strip-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 5 6v6c0 5 3.4 8.3 7 9 3.6-.7 7-4 7-9V6l-7-3Z"></path>
            <path d="m9.2 12 1.9 1.9 3.8-3.8"></path>
          </svg>
        </div>
        <h3>Güçlendirilmiş Çelik Gövde</h3>
        <p>Yüksek dayanım sağlayan sağlam iç konstrüksiyon.</p>
      </article>

      <article class="feature-strip-item">
        <div class="feature-strip-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 10h3.2L11 7v10l-3.8-3H4z"></path>
            <path d="M15 9a4 4 0 0 1 0 6"></path>
            <path d="M17.5 6.5a7.5 7.5 0 0 1 0 11"></path>
          </svg>
        </div>
        <h3>Ses &amp; Isı Yalıtımı</h3>
        <p>Konforlu kullanım için gelişmiş yalıtım desteği.</p>
      </article>

      <article class="feature-strip-item">
        <div class="feature-strip-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 5.5 6v6c0 4.6 3 7.6 6.5 9 3.5-1.4 6.5-4.4 6.5-9V6L12 3Z"></path>
            <path d="m9.6 12.8 1.7 1.7 3.2-3.2"></path>
            <path d="M11.3 8.8c.8-.8 1.4-1.4 1.4-2.4 1.3 1 2 2.3 2 3.6 0 1.9-1.5 3.2-3 3.2-1.6 0-2.7-1.2-2.7-2.5 0-1 .6-1.7 1.4-2.2"></path>
          </svg>
        </div>
        <h3>Yangına Dayanıklı Sistem</h3>
        <p>Güvenlik standartlarına uygun dayanıklı yapı.</p>
      </article>

      <article class="feature-strip-item">
        <div class="feature-strip-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9h8.7l2.5 2.5H18a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-3.8L11.7 19H3z"></path>
            <path d="M7.5 16.5V21h3v-4.5"></path>
            <path d="M20 14h3"></path>
            <path d="M5.8 12.2h2.2"></path>
          </svg>
        </div>
        <h3>Profesyonel Montaj</h3>
        <p>Uzman ekip ile hızlı ve güvenli kurulum.</p>
      </article>
    </div>
  </div>
</section>

<!-- DELIVERY BANNER -->
<section class="delivery-banner" aria-label="İstanbul ve Marmara ücretsiz teslimat ve kurulum">
  <div class="container">
    <div class="delivery-banner-grid">
      <div class="delivery-banner-card">
        <Image
          src={deliveryMarmara}
          alt="İstanbul ve Marmara bölgesinde ücretsiz teslimat ve kurulum hizmeti"
          loading="lazy"
          widths={[640, 900, 1280, 1600]}
          sizes="(max-width: 992px) 100vw, 62vw"
        />
      </div>
      <aside class="delivery-banner-copy">
        <div class="delivery-kicker">Ücretsiz Hizmet Bölgesi</div>
        <h3>İstanbul ve Marmara’da <span>teslimat + kurulum</span> bizden.</h3>
        <p>Kapınız üretimden çıktığı anda planlı sevkiyat sürecini başlatıyor, uzman ekibimizle montajı hızlı ve güvenli şekilde tamamlıyoruz.</p>
        <ul class="delivery-points">
          <li>Ücretsiz sevkiyat organizasyonu</li>
          <li>Uzman ekip ile yerinde kurulum</li>
          <li>Randevulu, düzenli teslimat süreci</li>
        </ul>
        <a href="/iletisim/" class="btn-primary">Teslimat Planı Oluştur</a>
      </aside>
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="featured">
  <div class="container">
    <div class="section-head centered featured-head">
      <div class="section-label">Öne Çıkan Modeller</div>
      <h2 class="section-title">En çok tercih edilen<br>kapı modelleri</h2>
      <a href="/urunler/" class="btn-outline-dark" style="margin-bottom:14px; white-space:nowrap;">Tüm Ürünleri Gör</a>
    </div>

    <div class="featured-cards-grid">
      {featuredProducts.map((product) => (
        <article class="product-card" data-category={product.data.category} data-product-slug={product.slug}>
          <a class="card-image-link" href={`/${product.slug}/`}>
            <div class="card-image-wrap">
              <img src={product.data.image} alt={`${product.data.title} görseli`} loading="lazy" />
            </div>
            <div class="hover-overlay"><span>Ürünü İncele →</span></div>
          </a>

          <div class="card-body">
            <span class:list={["category-badge", badgeClassMap[product.data.category]]}>{categoryMap[product.data.category]}</span>
            <h3 class="product-title">{product.data.title}</h3>
            <p class="product-material">{product.data.material}</p>
            <p class="model-code">Model: {product.data.modelCode}</p>
            <p class="product-desc">{product.data.shortDescription}</p>

            <div class="specs-box" aria-label="Ölçü ve renk bilgisi">
              <div class="spec-item">
                <span class="spec-label">Ölçü</span>
                <span class="spec-value">{product.data.size}</span>
              </div>
              <span class="spec-dot" aria-hidden="true"></span>
              <div class="spec-item">
                <span class="spec-label">Renk</span>
                <span class="spec-value">{product.data.color}</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- INSTALLATION QUALITY -->
<section class="installation-quality" aria-labelledby="installation-quality-title">
  <div class="container">
    <div class="section-head centered installation-quality-head">
      <div class="section-label">Çelik Kapı Özellikleri</div>
      <h2 class="section-title" id="installation-quality-title">Güvenlik ve konforu bir araya getiren teknik yapı</h2>
      <p class="section-desc">Üretimde tercih ettiğimiz malzeme kalitesi ve güvenlik bileşenleri sayesinde kapılarımız, uzun ömürlü kullanım ve yüksek dayanım standardı sunar. Estetik görünümü güçlü teknik altyapıyla birleştirerek yaşam alanlarınıza değer katıyoruz.</p>
    </div>

    <div class="installation-quality-grid">
      <div class="installation-quality-media">
        <Image
          src={technicalCutaway}
          alt="Uzman ekip ile çelik kapı montaj ve teslimat süreci"
          width="1086"
          height="1448"
          loading="lazy"
          decoding="async"
          widths={[420, 640, 900]}
          sizes="(max-width: 992px) 100vw, 48vw"
        />
      </div>

      <div class="installation-quality-content">
        <h3>Öne Çıkan Teknik Detaylar</h3>
        <ul class="installation-feature-list">
          <li>
            <div class="feature-dot"></div>
            <span>4 mm’ye Varan Güçlendirilmiş Çelik Gövde</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Monoblok Kilit Sistemi ile Maksimum Güvenlik</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Isı ve Ses Yalıtımında Üst Seviye Performans</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Gizli emniyet kelepçesi, 180° dürbün, kaliteli kapı kolu</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>5 yıl garanti desteği</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PROJECT SECTION -->
<section class="projects-section">
  <div class="container">
    <div class="projects-inner">
      <div class="projects-visual">
        <div class="project-production-media">
          <Image
            class="project-production-image"
            src={projectProduction}
            alt="Proje bazlı üretim için çelik kapı görseli"
            loading="lazy"
            decoding="async"
            widths={[420, 640, 900]}
            sizes="(max-width: 992px) 100vw, 40vw"
          />
        </div>
      </div>
      <div class="projects-content">
        <div class="section-label">Proje Bazlı Üretim</div>
        <h2 class="section-title" style="font-size:36px;">Özel ölçü ve proje bazlı üretim desteği</h2>
        <p class="section-desc">Apartman, villa, iş yeri ve toplu konut projelerinde ihtiyaca uygun ölçü, model ve kullanım senaryosuna göre kapı çözümleri sunuyoruz.</p>
        <ul class="project-features">
          <li>
            <div class="feature-dot"></div>
            <span>Özel ölçü üretim — standart dışı boyutlarda sorunsuz üretim</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Model ve renk seçenekleri — projeye uygun görsel çözümler</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Yangın kapısı ve bina giriş kapısı çözümleri</span>
          </li>
          <li>
            <div class="feature-dot"></div>
            <span>Teklif ve keşif süreci desteği — başlangıçtan teslimata kadar</span>
          </li>
        </ul>
        <a href="/iletisim/" class="btn-primary" style="padding:13px 28px; font-size:15px;">Projeniz İçin Teklif Alın</a>
      </div>
    </div>
  </div>
</section>

<!-- WHY US -->
<section class="why-us">
  <div class="container">
    <div class="section-head centered">
      <div class="section-label">Neden Biz?</div>
      <h2 class="section-title light">Güven veren üretim, net süreç</h2>
      <p class="section-desc light">Üretim kalitesi, özel ölçü yaklaşımı ve hızlı iletişim desteğiyle projelerinize güvenilir çözümler sunuyoruz.</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Dayanıklı Üretim</h3>
        <p>Uzun ömürlü kullanım için sağlam malzeme ve dikkatli işçilik. Her kapı titizlikle üretilir.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <h3>Özel Ölçü Çözümler</h3>
        <p>Farklı mekân ihtiyaçlarına uygun ölçü ve model seçenekleri. Standart dışı projeler için üretim.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h3>Güvenlik Odaklı Tasarım</h3>
        <p>Kullanım alanına göre güvenlik ve dayanıklılık öncelikli ürün yaklaşımı ile üretim.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.34 2 2 0 0 1 3.9 1H7a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
