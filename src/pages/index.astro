<script is:inline>
  const homeForm = document.getElementById("home-whatsapp-form");
  if (homeForm) {
    homeForm.addEventListener("submit", (event) => {
      event.preventDefault();

      const name = document.getElementById("home-name")?.value?.trim() ?? "";
      const phone = document.getElementById("home-phone")?.value?.trim() ?? "";
      const email = document.getElementById("home-email")?.value?.trim() ?? "";
      const category = document.getElementById("home-category")?.value?.trim() ?? "";
      const size = document.getElementById("home-size")?.value?.trim() ?? "";
      const message = document.getElementById("home-message")?.value?.trim() ?? "";

      if (!name || !phone || !message) {
        alert("Lütfen Ad Soyad, Telefon ve Mesaj alanlarını doldurun.");
        return;
      }

      const lines = [
        "Merhaba, teklif almak istiyorum.",
        `Ad Soyad: ${name}`,
        `Telefon: ${phone}`,
        `Kategori: ${category || "-"}`,
        `Ölçü: ${size || "-"}`,
        `E-posta: ${email || "-"}`,
        `Mesaj: ${message}`,
      ];

      const text = encodeURIComponent(lines.join("\n"));
      const url = `https://wa.me/905320605413?text=${text}`;
      window.location.href = url;
    });
  }
</script>

