---

<BaseLayout title="Projeler | Arslan Çelik Kapı" description="Tamamlanan çelik kapı, yangın kapısı ve bina giriş kapısı proje referansları.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon">AK</span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a class="active" href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905326470613">0532 647 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero references-hero">
      <div class="container hero-inner references-hero-inner">
        <h1>Proje <span>Referansları</span></h1>
        <p>
          Bugüne kadar 60 farklı firmada, 500’ün üzerinde üretim ve montaj sürecini başarıyla tamamladık.
          Aşağıda iş birliği yaptığımız firmalardan seçili referanslarımızı inceleyebilirsiniz.
        </p>
        <div class="references-stats" aria-label="Referans istatistikleri">
          <div class="stat-box">
            <strong>60+</strong>
            <span>Firma</span>
          </div>
          <div class="stat-box">
            <strong>500+</strong>
            <span>Üretim</span>
          </div>
        </div>
      </div>
    </section>

    <section class="references-list-section">
      <div class="container">
        <div class="references-frame">
          <ol class="references-list">
            {
              references.map((item, index) => (
                <li class="reference-item">
                  <div class="reference-index">{String(index + 1).padStart(2, "0")}</div>
                  <div class="reference-content">
                    <h2>{item.company}</h2>
                    <p>{item.work}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>
  </main>

  <style>
    .references-hero-inner {
      text-align: center;
    }

    .references-hero-inner h1 {
      margin-inline: auto;
      text-align: center;
    }

    .references-hero-inner p {
      margin-inline: auto;
      text-align: center;
      max-width: 860px;
    }

    .references-stats {
      margin-top: 24px;
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .stat-box {
      min-width: 132px;
      padding: 12px 18px;
      border: 1px solid rgba(199, 131, 43, 0.35);
      border-radius: 12px;
      background: rgba(199, 131, 43, 0.14);
      color: #f2eee7;
      text-align: center;
    }

    .stat-box strong {
      display: block;
      font-size: 26px;
      letter-spacing: -0.5px;
      line-height: 1;
      font-family: "Manrope", sans-serif;
    }

    .stat-box span {
      display: block;
      margin-top: 5px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #d8c8b1;
      font-weight: 700;
    }

    .references-list-section {
      padding: clamp(34px, 7vw, 84px) 0;
    }

    .references-frame {
      border-radius: 22px;
      border: 1px solid #e5dfd4;
      background: linear-gradient(180deg, #fffdfa 0%, #f8f4ec 100%);
      box-shadow: 0 20px 44px rgba(23, 18, 9, 0.08);
      overflow: hidden;
    }

    .references-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .reference-item {
      display: grid;
      grid-template-columns: 62px minmax(0, 1fr);
      border-bottom: 1px solid #ece5d9;
      transition: background 0.2s ease;
    }

    .reference-item:last-child {
      border-bottom: none;
    }

    .reference-item:hover {
      background: rgba(199, 131, 43, 0.05);
    }

    .reference-index {
      border-right: 1px solid #ece5d9;
      display: grid;
      place-items: center;
      font-family: "Manrope", sans-serif;
      font-weight: 800;
      color: #c7832b;
      letter-spacing: 0.04em;
      font-size: 13px;
      background: rgba(255, 255, 255, 0.62);
    }

    .reference-content {
      padding: 20px 22px;
      display: grid;
      gap: 6px;
    }

    .reference-content h2 {
      margin: 0;
      font-size: clamp(16px, 2vw, 19px);
      letter-spacing: -0.2px;
      color: #181512;
      font-weight: 800;
      font-family: "Manrope", sans-serif;
    }

    .reference-content p {
      margin: 0;
      font-size: 15px;
      line-height: 1.66;
      color: #575048;
    }

    @media (max-width: 680px) {
      .references-stats {
        gap: 10px;
      }

      .stat-box {
        min-width: 118px;
        padding: 10px 14px;
      }

      .reference-item {
        grid-template-columns: 48px minmax(0, 1fr);
      }

      .reference-content {
        padding: 16px 14px 16px 15px;
      }

      .reference-content p {
        font-size: 14px;
      }
    }
  </style>
</BaseLayout>


