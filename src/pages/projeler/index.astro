---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReferenceLogos from "../../components/ReferenceLogos.astro";

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";

const references = [
  {
    company: "Kayailli İnşaat",
  },
  {
    company: "Yalçınkaya Yapı İnşaat San. ve Tic. A.Ş.",
  },
  {
    company: "Demirhan İnşaat",
  },
  {
    company: "Doer Yapı Limited Şirketi",
  },
  {
    company: "Ersevin İnşaat Erol Sevindik",
  },
  {
    company: "NMK Yapı Ahşap Mimarlık San. Tic. Ltd. Şti.",
  },
  {
    company: "Miraç Mühendislik Mimarlık Proje Danışmanlık İnşaat Mobilya",
  },
  {
    company: "Çakmak İnşaat Müteahhitlik Hizmetleri Ltd. Şti.",
  },
  {
    company: "Base İnşaat Bilgisayar Yazılım A.Ş.",
  },
  {
    company: "DMR Teknik İnşaat Yapı Malzemeleri Turizm Tic. A.Ş.",
  },
  {
    company: "Adenis İnşaat Taahhüt Turizm San. ve Tic. A.Ş.",
  },
  {
    company: "Çiloğlu İnşaat",
  },
  {
    company: "Baytar İnşaat",
  },
  {
    company: "Alkılıç İnşaat",
  },
  {
    company: "Yapıtek",
  },
  {
    company: "Tozkoparan İnş",
  },
];
---

<BaseLayout title="Projeler | Arslan Çelik Kapı" description="Tamamlanan çelik kapı, yangın kapısı ve bina giriş kapısı proje referansları.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a href="/urunler/">Ürünler</a>
        <a class="active" href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero references-hero">
      <div class="container hero-inner references-hero-inner">
        <h1>Proje <span>Referansları</span></h1>
        <p>
          Çelik kapı, bina giriş kapısı ve yangın kapısı çözümlerinde; farklı ölçeklerdeki inşaat projeleri için
          60’tan fazla referans firmaya 500’ün üzerinde üretim ve montaj uygulamasını yüksek kalite standartlarıyla
          başarıyla tamamladık. Aşağıda, birlikte çalıştığımız seçili iş ortaklarımızı inceleyebilirsiniz.
        </p>
        <div class="references-stats" aria-label="Referans istatistikleri">
          <div class="stat-box">
            <strong>60+</strong>
            <span>Firma</span>
          </div>
          <div class="stat-box">
            <strong>500+</strong>
            <span>Üretim</span>
          </div>
        </div>
      </div>
    </section>

    <ReferenceLogos />

    <section class="references-list-section">
      <div class="container">
        <div class="references-frame">
          <ol class="references-list">
            {
              references.map((item, index) => (
                <li class="reference-item">
                  <div class="reference-index">{String(index + 1).padStart(2, "0")}</div>
                  <div class="reference-content">
                    <h2>{item.company}</h2>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </section>
  </main>

  <style>
    .references-hero-inner {
      text-align: center;
    }

    .references-hero-inner h1 {
      margin-inline: auto;
      text-align: center;
    }

    .references-hero-inner p {
      margin-inline: auto;
      text-align: center;
      max-width: 860px;
    }

    .references-stats {
      margin-top: 24px;
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .stat-box {
      min-width: 132px;
      padding: 12px 18px;
      border: 1px solid rgba(199, 131, 43, 0.35);
      border-radius: 12px;
      background: rgba(199, 131, 43, 0.14);
      color: #f2eee7;
      text-align: center;
    }

    .stat-box strong {
      display: block;
      font-size: 26px;
      letter-spacing: -0.5px;
      line-height: 1;
      font-family: "Manrope", sans-serif;
    }

    .stat-box span {
      display: block;
      margin-top: 5px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #d8c8b1;
      font-weight: 700;
    }

    .references-list-section {
      padding: clamp(34px, 7vw, 84px) 0;
    }

    .references-frame {
      border-radius: 22px;
      border: 1px solid #e5dfd4;
      background: linear-gradient(180deg, #fffdfa 0%, #f8f4ec 100%);
      box-shadow: 0 20px 44px rgba(23, 18, 9, 0.08);
      overflow: hidden;
    }

    .references-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .reference-item {
      display: grid;
      grid-template-columns: 62px minmax(0, 1fr);
      border-bottom: 1px solid #ece5d9;
      transition: background 0.2s ease;
    }

    .reference-item:last-child {
      border-bottom: none;
    }

    .reference-item:hover {
      background: rgba(199, 131, 43, 0.05);
    }

    .reference-index {
      border-right: 1px solid #ece5d9;
      display: grid;
      place-items: center;
      font-family: "Manrope", sans-serif;
      font-weight: 800;
      color: #c7832b;
      letter-spacing: 0.04em;
      font-size: 13px;
      background: rgba(255, 255, 255, 0.62);
    }

    .reference-content {
      padding: 20px 22px;
      display: grid;
      gap: 6px;
    }

    .reference-content h2 {
      margin: 0;
      font-size: clamp(17px, 2vw, 21px);
      letter-spacing: -0.2px;
      color: #181512;
      font-weight: 600;
      font-style: italic;
      font-family: "Playfair Display", "Cormorant Garamond", Georgia, serif;
      line-height: 1.35;
    }

    @media (max-width: 680px) {
      .references-stats {
        gap: 10px;
      }

      .stat-box {
        min-width: 118px;
        padding: 10px 14px;
      }

      .reference-item {
        grid-template-columns: 48px minmax(0, 1fr);
      }

      .reference-content {
        padding: 14px 14px 14px 15px;
      }
    }
  </style>
</BaseLayout>





