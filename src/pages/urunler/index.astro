---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const categoryMap = {
  "celik-kapi": "Çelik Kapı",
  "yangin-kapisi": "Yangın Kapısı",
  "bina-giris-kapisi": "Bina Giriş Kapısı",
} as const;

const selectedCategory = Astro.url.searchParams.get("kategori");
const products = (await getCollection("products", ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title, "tr"),
);

const filteredProducts = selectedCategory
  ? products.filter((entry) => entry.data.category === selectedCategory)
  : products;
const whatsappQuoteUrl =
  "https://wa.me/905326470613?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";
---

<BaseLayout title="Ürünler | Arslan Çelik Kapı" description="Çelik kapı, yangın kapısı ve bina giriş kapısı ürün listesi.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon">AK</span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a class="active" href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <span class="hero-label">Ürün Listesi</span>
        <h1>Kapı <span>Modelleri</span></h1>
        <p>Farklı kullanım alanları için geliştirdiğimiz modelleri inceleyin. Ürün detayları müşteri panelinden kolayca güncellenebilir.</p>
      </div>
    </section>

    <section class="products-section">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">Ürünler</h2>
            <p class="section-desc">Üstteki kategorilerden filtreleme yapabilir, kartlarda ürün adı, model kodu, ölçü, renk ve malzeme bilgilerini görebilirsiniz.</p>
          </div>
        </div>

        <nav class="category-nav" aria-label="Ürün kategorileri">
          <a class:list={["category-link", !selectedCategory && "active"]} href="/urunler/">Tüm Ürünler</a>
          <a class:list={["category-link", selectedCategory === "celik-kapi" && "active"]} href="/urunler/?kategori=celik-kapi">Çelik Kapı</a>
          <a class:list={["category-link", selectedCategory === "yangin-kapisi" && "active"]} href="/urunler/?kategori=yangin-kapisi">Yangın Kapısı</a>
          <a class:list={["category-link", selectedCategory === "bina-giris-kapisi" && "active"]} href="/urunler/?kategori=bina-giris-kapisi">Bina Giriş Kapısı</a>
        </nav>

        {
          filteredProducts.length > 0 ? (
            <div class="products-grid">
              {filteredProducts.map((product) => (
                <article class="product-card">
                  <div class="product-image-wrap">
                    <img class="product-image" src={product.data.image} alt={`${product.data.title} görseli`} loading="lazy" />
                  </div>
                  <div class="product-body">
                    <span class="product-category">{categoryMap[product.data.category]}</span>
                    <h3 class="product-title">{product.data.title}</h3>
                    <p class="product-code">Model Kodu: {product.data.modelCode}</p>
                    <p class="product-summary">{product.data.shortDescription}</p>
                    <div class="product-meta">
                      <div class="meta-item">
                        <span class="meta-label">Ölçü</span>
                        <span class="meta-value">{product.data.size}</span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Renk</span>
                        <span class="meta-value">{product.data.color}</span>
                      </div>
                      <div class="meta-item" style="grid-column: 1 / -1;">
                        <span class="meta-label">Malzeme</span>
                        <span class="meta-value">{product.data.material}</span>
                      </div>
                    </div>
                    <div class="product-actions">
                      <a class="product-link" href={`/urunler/${product.slug}/`}>Detay Sayfası</a>
                      <a class="btn-primary" href={`/urunler/${product.slug}/`}>İncele</a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="product-empty">Bu kategori için henüz ürün bulunmuyor.</div>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>

