---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const categoryMap = {
  "celik-kapi": "Çelik Kapı",
  "yangin-kapisi": "Yangın Kapısı",
  "bina-giris-kapisi": "Bina Giriş Kapısı",
} as const;

const hashOrder = (value: string) => {
  let hash = 0;
  for (let i = 0; i < value.length; i += 1) {
    hash = (hash * 31 + value.charCodeAt(i)) % 2147483647;
  }
  return hash;
};

const products = (await getCollection("products", ({ data }) => !data.draft)).sort((a, b) => {
  const aHash = hashOrder(a.slug);
  const bHash = hashOrder(b.slug);
  if (aHash !== bHash) return aHash - bHash;
  return a.data.title.localeCompare(b.data.title, "tr");
});

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";
---

<BaseLayout title="Ürünler | Arslan Çelik Kapı" description="Çelik kapı, yangın kapısı ve bina giriş kapısı ürün listesi.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a class="active" href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main>
    <section class="hero products-hero">
      <div class="container hero-inner">
        <h1>Kapı <span>Modelleri</span></h1>
        <p>
          Çelik kapı modellerimiz, konut ve iş yeri girişlerinde güvenlik ile estetiği bir araya getirir.
          Yangın kapısı modellerimiz, yönetmeliklere uygun koruma ve dayanım sağlar.
          Bina giriş kapısı çözümlerimiz ise apartman ve site projelerinde mimariye uyumlu, güçlü ve uzun ömürlü kullanım sunar.
        </p>
      </div>
    </section>

    <section class="products-section">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">Ürünler</h2>
            <p class="section-desc">Üstteki kategorilerden filtreleme yapabilir, kartlarda ürün adı, model kodu, ölçü, renk ve malzeme bilgilerini görebilirsiniz.</p>
          </div>
        </div>

        <nav class="category-nav" aria-label="Ürün kategorileri">
          <a class="category-link" href="/urunler/">Tüm Ürünler</a>
          <a class="category-link" href="/urunler/?kategori=celik-kapi">Çelik Kapı</a>
          <a class="category-link" href="/urunler/?kategori=yangin-kapisi">Yangın Kapısı</a>
          <a class="category-link" href="/urunler/?kategori=bina-giris-kapisi">Bina Giriş Kapısı</a>
        </nav>

        {products.length > 0 ? (
          <>
            <div class="products-grid">
              {products.map((product) => (
                <article class="product-card" data-category={product.data.category}>
                  <div class="product-image-wrap" style="background:#fff;">
                    <img class="product-image" src={product.data.image} alt={`${product.data.title} görseli`} loading="lazy" />
                  </div>
                  <div class="product-body">
                    <span class="product-category">{categoryMap[product.data.category]}</span>
                    <h3 class="product-title">{product.data.title}</h3>
                    <p class="product-code">Model Kodu: {product.data.modelCode}</p>
                    <p class="product-summary">{product.data.shortDescription}</p>
                    <div class="product-meta">
                      <div class="meta-item">
                        <span class="meta-label">Ölçü</span>
                        <span class="meta-value">{product.data.size}</span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Renk</span>
                        <span class="meta-value">{product.data.color}</span>
                      </div>
                      <div class="meta-item" style="grid-column: 1 / -1;">
                        <span class="meta-label">Malzeme</span>
                        <span class="meta-value">{product.data.material}</span>
                      </div>
                    </div>
                    <div class="product-actions">
                      <a class="product-link" href={`/urunler/${product.slug}/`}>Detay Sayfası</a>
                      <a class="btn-primary" href={`/urunler/${product.slug}/`}>İncele</a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
            <div class="product-empty" id="product-empty-state" style="display: none;">Bu kategori için henüz ürün bulunmuyor.</div>
          </>
        ) : (
          <div class="product-empty">Henüz ürün bulunmuyor.</div>
        )}
      </div>
    </section>
  </main>

  <style>
    .products-grid .product-card,
    .products-grid .product-body,
    .products-grid .product-image-wrap {
      background: #ffffff !important;
    }

    .products-hero .hero-inner h1 {
      width: 100%;
      text-align: center;
      margin-inline: auto;
    }

    .products-hero .hero-inner p {
      max-width: 860px;
      margin-inline: auto;
      text-align: center;
    }
  </style>

  <script is:inline>
    const categoryNav = document.querySelector(".category-nav");
    if (categoryNav) {
      const currentCategory = (new URLSearchParams(window.location.search).get("kategori") || "").trim();
      const links = [...categoryNav.querySelectorAll(".category-link")];
      const cards = [...document.querySelectorAll(".product-card")];
      const emptyState = document.getElementById("product-empty-state");

      links.forEach((link) => link.classList.remove("active"));

      const activeLink = links.find((link) => {
        const linkCategory = new URL(link.href, window.location.origin).searchParams.get("kategori") || "";
        return linkCategory.trim() === currentCategory;
      });

      if (activeLink) activeLink.classList.add("active");

      let visibleCount = 0;
      cards.forEach((card) => {
        const cardCategory = (card.getAttribute("data-category") || "").trim();
        const isVisible = !currentCategory || cardCategory === currentCategory;
        card.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.style.display = visibleCount > 0 ? "none" : "block";
      }
    }
  </script>
</BaseLayout>

