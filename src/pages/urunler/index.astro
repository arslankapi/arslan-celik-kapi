---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const categoryMap = {
  "celik-kapi": "Çelik Kapı",
  "yangin-kapisi": "Yangın Kapısı",
  "bina-giris-kapisi": "Bina Giriş Kapısı",
} as const;

const badgeClassMap = {
  "celik-kapi": "badge-orange",
  "bina-giris-kapisi": "badge-mustard",
  "yangin-kapisi": "badge-yellow",
} as const;

const formatProductPrice = (value: string | number | undefined) => {
  if (value === undefined || value === null || value === "") return null;

  if (typeof value === "number" && Number.isFinite(value)) {
    return new Intl.NumberFormat("tr-TR", {
      style: "currency",
      currency: "TRY",
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(value);
  }

  const normalized = String(value)
    .trim()
    .replace(/\s+/g, "")
    .replace(/₺|TL|TRY/gi, "");

  if (!normalized) return null;

  let numeric = normalized;
  if (numeric.includes(".") && numeric.includes(",")) {
    numeric = numeric.lastIndexOf(",") > numeric.lastIndexOf(".")
      ? numeric.replace(/\./g, "").replace(",", ".")
      : numeric.replace(/,/g, "");
  } else if (numeric.includes(",")) {
    numeric = numeric.replace(",", ".");
  }

  const parsed = Number.parseFloat(numeric);
  if (!Number.isFinite(parsed)) return null;

  return new Intl.NumberFormat("tr-TR", {
    style: "currency",
    currency: "TRY",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(parsed);
};

const hashOrder = (value: string) => {
  let hash = 0;
  for (let i = 0; i < value.length; i += 1) {
    hash = (hash * 31 + value.charCodeAt(i)) % 2147483647;
  }
  return hash;
};

const products = (await getCollection("products", ({ data }) => !data.draft)).sort((a, b) => {
  const aHash = hashOrder(a.slug);
  const bHash = hashOrder(b.slug);
  if (aHash !== bHash) return aHash - bHash;
  return a.data.title.localeCompare(b.data.title, "tr");
});

const whatsappQuoteUrl =
  "https://wa.me/905320605413?text=Merhaba%2C%20Arslan%20%C3%87elik%20Kap%C4%B1%20i%C3%A7in%20teklif%20almak%20istiyorum.";
---

<BaseLayout title="Ürünler | Arslan Çelik Kapı" description="Çelik kapı, yangın kapısı ve bina giriş kapısı ürün listesi.">
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">
        <span class="logo-icon"><img src="/images/logo/logo-mark.png" alt="Arslan Çelik Kapı logosu" loading="eager" decoding="async" /></span>
        <span class="logo-text">
          <span class="brand">ARSLAN ÇELİK KAPI</span>
          <span class="sub">Özel Ölçü Üretim</span>
        </span>
      </a>
      <nav class="header-links" aria-label="Ana menü">
        <a class="active" href="/urunler/">Ürünler</a>
        <a href="/projeler/">Projeler</a>
        <a href="/hakkimizda/">Hakkımızda</a>
        <a href="/blog/">Blog</a>
        <a href="/iletisim/">İletişim</a>
      </nav>
      <a class="header-phone" href="tel:+905416430613"><svg viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>0541 643 06 13</a>
      <a class="btn-primary" href={whatsappQuoteUrl} target="_blank" rel="noopener noreferrer">Teklif Al</a>
    </div>
  </header>

  <main id="main-content">
    <section class="hero products-hero">
      <div class="container hero-inner">
        <h1>Kapı <span>Modelleri</span></h1>
        <p>
          Çelik kapı modellerimiz, konut ve iş yeri girişlerinde güvenlik ile estetiği bir araya getirir.
          Yangın kapısı modellerimiz, yönetmeliklere uygun koruma ve dayanım sağlar.
          Bina giriş kapısı çözümlerimiz ise apartman ve site projelerinde mimariye uyumlu, güçlü ve uzun ömürlü kullanım sunar.
        </p>
      </div>
    </section>

    <section class="products-section">
      <div class="container">
        <div class="section-head">
          <div>
            <h2 class="section-title">Ürünler</h2>
            <p class="section-desc">Üstteki kategorilerden filtreleme yapabilir, kartlarda ürün adı, model kodu, ölçü, renk ve malzeme bilgilerini görebilirsiniz.</p>
          </div>
        </div>

        <nav class="category-nav" aria-label="Ürün kategorileri">
          <a class="category-link" href="/urunler/">Tüm Ürünler</a>
          <a class="category-link" href="/urunler/?kategori=celik-kapi">Çelik Kapı</a>
          <a class="category-link" href="/urunler/?kategori=yangin-kapisi">Yangın Kapısı</a>
          <a class="category-link" href="/urunler/?kategori=bina-giris-kapisi">Bina Giriş Kapısı</a>
        </nav>

        {products.length > 0 ? (
          <>
            <div class="cards-grid">
              {products.map((product) => (
                <article class="product-card" data-category={product.data.category}>
                  <a class="card-image-link" href={`/${product.slug}/`}>
                    <div class="card-image-wrap">
                      <img src={product.data.image} alt={`${product.data.title} görseli`} loading="lazy" />
                    </div>
                    <div class="hover-overlay"><span>Ürünü İncele →</span></div>
                  </a>

                  <div class="card-body">
                    {product.data.price !== undefined && <p class="product-price">{formatProductPrice(product.data.price)}</p>}
                    <span class:list={["category-badge", badgeClassMap[product.data.category]]}>{categoryMap[product.data.category]}</span>
                    <h3 class="product-title">{product.data.title}</h3>
                    <p class="product-material">{product.data.material}</p>
                    <p class="model-code">Model: {product.data.modelCode}</p>
                    <p class="product-desc">{product.data.shortDescription}</p>

                    <div class="specs-box" aria-label="Ölçü ve renk bilgisi">
                      <div class="spec-item">
                        <span class="spec-label">Ölçü</span>
                        <span class="spec-value">{product.data.size}</span>
                      </div>
                      <span class="spec-dot" aria-hidden="true"></span>
                      <div class="spec-item">
                        <span class="spec-label">Renk</span>
                        <span class="spec-value">{product.data.color}</span>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
            <div class="product-empty" id="product-empty-state" style="display: none;">Bu kategori için henüz ürün bulunmuyor.</div>
          </>
        ) : (
          <div class="product-empty">Henüz ürün bulunmuyor.</div>
        )}
      </div>
    </section>
  </main>
  <style>
    .products-section {
      font-family: "DM Sans", sans-serif;
    }

    .products-hero .hero-inner h1 {
      width: 100%;
      text-align: center;
      margin-inline: auto;
    }

    .products-hero .hero-inner p {
      max-width: 860px;
      margin-inline: auto;
      text-align: center;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
      width: 100%;
    }

    .product-card {
      background: #fff;
      border: 0.5px solid rgba(0, 0, 0, 0.12);
      border-radius: 10px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: border-color 0.2s, transform 0.18s;
    }

    .product-card:hover {
      border-color: rgba(0, 0, 0, 0.28);
      transform: translateY(-3px);
      box-shadow: none;
    }

    .card-image-link {
      display: block;
      position: relative;
      text-decoration: none;
      cursor: pointer;
    }

    .card-image-wrap {
      width: 100%;
      height: clamp(320px, 28vw, 420px);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #ffffff;
      transition: opacity 0.2s;
      padding: 16px;
      border-bottom: 0.5px solid rgba(0, 0, 0, 0.06);
    }

    .card-image-wrap img {
      width: 92%;
      height: 92%;
      max-width: 92%;
      max-height: 92%;
      object-fit: contain;
      object-position: center;
      display: block;
    }

    .card-image-link:hover .card-image-wrap {
      opacity: 0.92;
    }

    .card-image-link:hover .hover-overlay {
      opacity: 1;
    }

    .hover-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.1);
      opacity: 0;
      transition: opacity 0.2s;
    }

    .hover-overlay span {
      background: rgba(255, 255, 255, 0.92);
      color: #222;
      font-size: 12px;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 20px;
    }

    .card-body {
      padding: 12px 14px 14px;
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .product-price {
      margin: 0;
      font-family: "Manrope", sans-serif;
      font-size: 18px;
      font-weight: 800;
      line-height: 1;
      color: #1a1a1a;
      letter-spacing: -0.03em;
    }

    .category-badge {
      align-self: flex-start;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 4px;
      letter-spacing: 0.01em;
      display: inline-flex;
      align-items: center;
    }

    .badge-orange {
      background: #d5852f;
      color: #ffffff;
      border: 0.5px solid #b86b1e;
    }

    .badge-mustard {
      background: #b38a1f;
      color: #ffffff;
      border: 0.5px solid #916f14;
    }

    .badge-yellow {
      background: #d1b531;
      color: #ffffff;
      border: 0.5px solid #ad9524;
    }

    .product-title {
      font-family: "DM Serif Display", serif;
      font-size: 16px;
      font-weight: 400;
      color: #1a1a1a;
      line-height: 1.25;
      margin: 0;
    }

    .product-material {
      font-size: 11px;
      color: #6b6b6b;
      margin: 0;
    }

    .model-code {
      font-size: 10.5px;
      color: #9b9b9b;
      margin: 0;
    }

    .product-desc {
      font-size: 11.5px;
      color: #5c5c5c;
      line-height: 1.45;
      margin: 0;
    }

    .specs-box {
      background: #f5f4f1;
      border: 0.5px solid rgba(0, 0, 0, 0.08);
      border-radius: 6px;
      padding: 7px 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .spec-item {
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
    }

    .spec-label {
      color: #9b9b9b;
      font-size: 10.5px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .spec-value {
      color: #1a1a1a;
      font-weight: 500;
      font-size: 12px;
    }

    .spec-dot {
      width: 3px;
      height: 3px;
      background: #c8c8c4;
      border-radius: 50%;
      flex-shrink: 0;
      display: inline-block;
    }

    @media (max-width: 960px) {
      .cards-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card-image-wrap {
        height: clamp(280px, 44vw, 360px);
        padding: 14px;
      }

      .card-image-wrap img {
        width: 90%;
        height: 90%;
        max-width: 90%;
        max-height: 90%;
      }
    }

    @media (max-width: 520px) {
      .cards-grid {
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .card-image-wrap {
        height: clamp(260px, 64vw, 320px);
        padding: 12px;
      }

      .card-image-wrap img {
        width: 90%;
        height: 90%;
        max-width: 90%;
        max-height: 90%;
      }

      .card-body {
        padding: 11px 12px 13px;
        gap: 6px;
      }

      .product-price {
        font-size: 16px;
      }
    }

    @media (max-width: 360px) {
      .cards-grid {
        grid-template-columns: 1fr;
      }

      .card-image-wrap {
        height: clamp(280px, 78vw, 340px);
      }
    }
  </style>


  <script is:inline>
    const categoryNav = document.querySelector(".category-nav");
    if (categoryNav) {
      const currentCategory = (new URLSearchParams(window.location.search).get("kategori") || "").trim();
      const links = [...categoryNav.querySelectorAll(".category-link")];
      const cards = [...document.querySelectorAll(".product-card")];
      const emptyState = document.getElementById("product-empty-state");

      links.forEach((link) => link.classList.remove("active"));

      const activeLink = links.find((link) => {
        const linkCategory = new URL(link.href, window.location.origin).searchParams.get("kategori") || "";
        return linkCategory.trim() === currentCategory;
      });

      if (activeLink) activeLink.classList.add("active");

      let visibleCount = 0;
      cards.forEach((card) => {
        const cardCategory = (card.getAttribute("data-category") || "").trim();
        const isVisible = !currentCategory || cardCategory === currentCategory;
        card.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.style.display = visibleCount > 0 ? "none" : "block";
      }
    }
  </script>
</BaseLayout>





